{
  "siteName": "GD Resources",
  "siteDescription": "Awesome Geometry Dash documentation & tools",
  "titleSuffix": "GD Resources",
  "faviconPath": "/favicon.png",
  "branding": {
    "display": "logo-only",
    "logoPath": "/logo.png",
    "logoAlt": "GD Resources logo",
    "text": "GD Resources",
    "logoClassName": "h-7 w-auto"
  },
  "wikiPreset": "docs",
  "defaultTemplate": "default",
  "header": {
    "showSearch": true,
    "showDarkModeToggle": true,
    "searchPlaceholder": "Search..."
  },
  "pageTemplates": {
    "enabled": true,
    "defaultTemplate": "default"
  },
  "editPage": {
    "enabled": true,
    "provider": "github",
    "repository": "OmgRod/gd-resources",
    "branch": "main",
    "contentPath": "content",
    "text": "Edit this page"
  },
  "layout": {
    "maxWidthClass": "max-w-7xl",
    "sidebarWidthClass": "md:w-72"
  }
}
